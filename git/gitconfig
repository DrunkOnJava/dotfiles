[user]
	name = Griffin Long
	email = griffinradcliffe@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub
[init]
	defaultBranch = main
[pull]
	rebase = false
[core]
	editor = code --wait
	excludesfile = ~/.gitignore_global
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
